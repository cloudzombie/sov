{
  "name": "@sov/sdk",
  "version": "0.1.0",
  "description": "High-level JavaScript/TypeScript client SDK for the SOV blockchain. Offline core (units, AccountId validation, Ed25519 keys, types & transaction builder) is real and unit-tested; the JSON-RPC client is the ready abstraction that activates with the Phase 8 node RPC.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "sov",
    "blockchain",
    "sdk",
    "ed25519",
    "client"
  ],
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "@noble/post-quantum": "^0.6.1",
    "@scure/base": "^1.2.6",
    "@scure/bip39": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
